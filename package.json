{
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm --prefix backend test -- --runInBand",
    "test:frontend": "npm --prefix frontend run test:run",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:realtime": "npm --prefix backend run test:e2e -- --testPathPattern=realtime-events"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
